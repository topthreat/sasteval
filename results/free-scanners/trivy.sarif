            {
              "id": "CVE-2026-25543",
              "name": "LanguageSpecificPackageVulnerability",
              "shortDescription": {
                "text": "HtmlSanitizer has a bypass via template tag"
              },
              "fullDescription": {
                "text": "HtmlSanitizer is a .NET library for cleaning HTML fragments and documents from constructs that can lead to XSS attacks. Prior to versions 9.0.892 and 9.1.893-beta, if the template tag is allowed, its contents are not sanitized. The template tag is a special tag that does not usually render its contents, unless the shadowrootmode attribute is set to open or closed. This issue has been patched in versions 9.0.892 and 9.1.893-beta."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://avd.aquasec.com/nvd/cve-2026-25543",
              "help": {
                "text": "Vulnerability CVE-2026-25543\nSeverity: MEDIUM\nPackage: HtmlSanitizer\nFixed Version: 9.0.892, 9.1.893-beta\nLink: [CVE-2026-25543](https://avd.aquasec.com/nvd/cve-2026-25543)\nHtmlSanitizer is a .NET library for cleaning HTML fragments and documents from constructs that can lead to XSS attacks. Prior to versions 9.0.892 and 9.1.893-beta, if the template tag is allowed, its contents are not sanitized. The template tag is a special tag that does not usually render its contents, unless the shadowrootmode attribute is set to open or closed. This issue has been patched in versions 9.0.892 and 9.1.893-beta.",
                "markdown": "**Vulnerability CVE-2026-25543**\n| Severity | Package | Fixed Version | Link |\n| --- | --- | --- | --- |\n|MEDIUM|HtmlSanitizer|9.0.892, 9.1.893-beta|[CVE-2026-25543](https://avd.aquasec.com/nvd/cve-2026-25543)|\n\nHtmlSanitizer is a .NET library for cleaning HTML fragments and documents from constructs that can lead to XSS attacks. Prior to versions 9.0.892 and 9.1.893-beta, if the template tag is allowed, its contents are not sanitized. The template tag is a special tag that does not usually render its contents, unless the shadowrootmode attribute is set to open or closed. This issue has been patched in versions 9.0.892 and 9.1.893-beta."
              },
              "properties": {
                "cvssv40_baseScore": 6.3,
                "cvssv40_vector": "CVSS:4.0/AV:N/AC:L/AT:P/PR:N/UI:N/VC:N/VI:N/VA:N/SC:L/SI:L/SA:N",
                "precision": "very-high",
